# Environment Configuration for Lexical Graph Workshop
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# Graph Database connection string
# Examples:
#   For Neptune Analytics:
#   GRAPH_STORE=wss://g-abc123.us-east-1.neptune-graph.amazonaws.com/
#   For Neptune Database:
#   GRAPH_STORE=wss://my-cluster.cluster-abc123.us-east-1.neptune.amazonaws.com:8182/gremlin
#   For Neo4j:
#   GRAPH_STORE=bolt://username:password@localhost:7687

# Vector Database connection string
# Examples:
#   For Neptune Analytics:
#   VECTOR_STORE=wss://g-abc123.us-east-1.neptune-graph.amazonaws.com/
#   For PostgreSQL (pgvector):
#   VECTOR_STORE=postgresql://user:password@localhost:5432/dbname

# Bedrock Models
EXTRACTION_MODEL=us.anthropic.claude-sonnet-4-6
RESPONSE_MODEL=us.anthropic.claude-sonnet-4-6
