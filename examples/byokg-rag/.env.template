# Environment Configuration for BYOKG-RAG
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# AWS Region
AWS_REGION=us-east-1

# Neptune Analytics Graph Identifier (for Neptune Analytics notebooks)
GRAPH_IDENTIFIER=<YOUR_GRAPH_IDENTIFIER>

# Neptune DB Cluster Endpoint URL (required for byokg_rag_neptune_db_cluster_demo.ipynb only)
# Uncomment and set if using that notebook:
# GRAPH_DB_ENDPOINT_URL=https://my-cluster.cluster-abc123.us-east-1.neptune.amazonaws.com:8182

# Bedrock Model
MODEL_NAME=us.anthropic.claude-sonnet-4-6

# Embeddings Model (for embeddings notebook)
EMBEDDINGS_MODEL=cohere.embed-english-v3
